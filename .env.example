# 数据库配置
# Database Configuration
DB_USERNAME=root
DB_PASSWORD=your_database_password

# 阿里云 OSS 配置
# Aliyun OSS Configuration
OSS_ACCESS_KEY_ID=your_aliyun_access_key_id
OSS_ACCESS_KEY_SECRET=your_aliyun_access_key_secret

# 环境配置（可选，默认为 dev）
# Environment Profile (optional, default is dev)
# SPRING_PROFILES_ACTIVE=dev

# 使用说明：
# 1. 复制此文件为 .env（不要提交到 Git）
# 2. 将上面的示例值替换为你的实际值
# 3. 在 IDEA 中配置环境变量，或在命令行中 export 这些变量
#
# Linux/Mac 使用方法：
#   export DB_USERNAME=root
#   export DB_PASSWORD=123456
#   export OSS_ACCESS_KEY_ID=LTAI5tYourAccessKey
#   export OSS_ACCESS_KEY_SECRET=YourSecretKey
#
# Windows 使用方法：
#   set DB_USERNAME=root
#   set DB_PASSWORD=123456
#   set OSS_ACCESS_KEY_ID=LTAI5tYourAccessKey
#   set OSS_ACCESS_KEY_SECRET=YourSecretKey
#
# IDEA 配置方法：
#   Run -> Edit Configurations -> Environment variables
#   添加上述变量（用分号分隔）：
#   DB_USERNAME=root;DB_PASSWORD=123456;OSS_ACCESS_KEY_ID=your_key;OSS_ACCESS_KEY_SECRET=your_secret
