sky:
  datasource:
    driver-class-name: com.mysql.cj.jdbc.Driver
    host: localhost
    port: 3306
    database: sky_take_out
    username: ${DB_USERNAME:root}
    password: ${DB_PASSWORD:123456}
  alioss:
    endpoint: oss-cn-beijing.aliyuncs.com
    region: cn-beijing
    # 方法1: 从环境变量读取（推荐用于生产环境）
    access-key: ${OSS_ACCESS_KEY_ID}
    secret-key: ${OSS_ACCESS_KEY_SECRET}
    # 方法2: 直接设置（仅用于开发环境，不要提交到Git）
    # access-key: LTAI5tYourAccessKeyID
    # secret-key: YourAccessKeySecret
    bucket-name: sky-takeout

# 配置说明:
# 1. 建议使用环境变量方式配置敏感信息（数据库密码、OSS凭证等）
# 2. 在 PowerShell 中设置环境变量: $env:OSS_ACCESS_KEY_ID = "你的值"
# 3. 在 CMD 中设置环境变量: set OSS_ACCESS_KEY_ID=你的值
# 4. 在 IntelliJ IDEA 中: Run -> Edit Configurations -> Environment variables
# 5. 详细配置方法请参考项目根目录的 ENVIRONMENT_SETUP.md 文件
