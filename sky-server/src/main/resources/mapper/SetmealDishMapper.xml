<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.sky.mapper.SetmealDishMapper">
    <insert id="save">
insert into setmeal_dish (setmeal_id, dish_id, name, price,copies) values
   <foreach collection="setmealDishes" item="s" separator=",">
            (#{s.setmealId}, #{s.dishId}, #{s.name}, #{s.price},#{s.copies})
   </foreach>


    </insert>
    <delete id="deleteBySetmealId">
        delete from setmeal_dish where setmeal_id = #{id}

    </delete>

    <select id="countByDishId" resultType="java.lang.Integer">
        select count(*) from setmeal_dish where dish_id in
     (
    <foreach collection="ids" item="id" separator="," >
        #{id}
    </foreach>

    )

    </select>
    <select id="getBySetmealId" resultType="com.sky.entity.SetmealDish">
        select * from setmeal_dish where setmeal_id = #{id}

    </select>
</mapper>